# ── App ──
NODE_ENV=development
PORT=3000

# ── Database ──
DATABASE_URL=postgresql://he_user:he_dev_password@localhost:5432/he_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=5000

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Auth ──
JWT_SECRET=dev-jwt-secret-64-chars-minimum-replace-in-production!!
JWT_REFRESH_SECRET=dev-refresh-secret-64-chars-minimum-replace-in-production!!
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── OAuth ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/v1/auth/oauth/google/callback

# ── Storage ──
S3_REGION=us-east-1
S3_BUCKET=he-app-audio-dev
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# ── AI Providers (OpenRouter) ──
# Get key from https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct
OPENROUTER_TIMEOUT_MS=60000
OPENROUTER_MAX_RETRIES=3
OPENROUTER_FALLBACK_MODEL=anthropic/claude-3-haiku-20240307

# ── AI Providers (AWS Bedrock — disabled, kept for reference) ──
# BEDROCK_API_KEY=
# AWS_REGION=us-east-1
# BEDROCK_SONNET_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
# BEDROCK_HAIKU_MODEL=anthropic.claude-3-5-haiku-20241022-v1:0
# BEDROCK_TIMEOUT_MS=30000
# BEDROCK_MAX_RETRIES=3

# ── Speech Providers ──
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# ── Email ──
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@he.app
SENDGRID_FROM_NAME=HE Language Learning

# ── Push Notifications ──
FIREBASE_SERVER_KEY=

# ── Monitoring ──
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
PROMETHEUS_ENABLED=true
PROMETHEUS_METRICS_PREFIX=he_
PROMETHEUS_DEFAULT_LABELS={app:"he-backend",env:"development"}

# ── Cost Controls ──
MONTHLY_HARD_CAP_CENTS=120000   # $1,200/month AI cost cap
DAILY_USER_LIMIT_CENTS=10       # $0.10/day per user
DAILY_GLOBAL_LIMIT_CENTS=5000   # $50/day total
COST_ALERT_WEBHOOK_URL=

# ── Beta ──
BETA_INVITE_CODES=beta2024,earlyaccess2024,friendsofhe

# ── Rate Limiting ──
THROTTLE_TTL=60
THROTTLE_LIMIT=100
THROTTLE_AUTH_LIMIT=10
