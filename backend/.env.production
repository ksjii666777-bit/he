# ── App ──
NODE_ENV=production
PORT=3000

# ── Database (Production) ──
# Railway PostgreSQL add-on provides this automatically as RAILWAY_DATABASE_URL
# Fallback: create a read-replica URL for reporting queries
DATABASE_URL=postgresql://he_user:CHANGE_ME@he-prod-postgres.railway.internal:5432/he_prod
DATABASE_REPLICA_URL=postgresql://he_user_readonly:CHANGE_ME@he-prod-postgres-replica.railway.internal:5432/he_prod
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=5000

# ── Redis (Production) ──
# Railway Redis add-on provides this automatically as RAILWAY_REDIS_URL
REDIS_URL=redis://:CHANGE_ME@he-prod-redis.railway.internal:6379
REDIS_USE_TLS=false
REDIS_KEY_PREFIX=he:prod:

# ── Auth ──
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_64_too
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── OAuth ──
# Register app at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.he.app/v1/auth/oauth/google/callback

# ── Storage (S3-compatible) ──
S3_REGION=us-east-1
S3_BUCKET=he-app-audio-prod
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# ── AI Providers (OpenRouter) ──
# Get key from https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct
OPENROUTER_TIMEOUT_MS=60000
OPENROUTER_MAX_RETRIES=3
OPENROUTER_FALLBACK_MODEL=anthropic/claude-3-haiku-20240307

# ── Speech Providers ──
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# ── Email ──
# Sign up at https://sendgrid.com (free: 100 emails/day)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@he.app
SENDGRID_FROM_NAME=HE Language Learning

# ── Push Notifications ──
FIREBASE_SERVER_KEY=

# ── Monitoring ──
# https://sentry.io/organizations/YOUR_ORG/projects/new/
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Prometheus Metrics ──
# Exposed on GET /metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_METRICS_PREFIX=he_
PROMETHEUS_DEFAULT_LABELS={app:"he-backend",env:"production"}

# ── Cost Controls ──
MONTHLY_HARD_CAP_CENTS=120000   # $1,200/month AI cost cap
DAILY_USER_LIMIT_CENTS=10       # $0.10/day per user
DAILY_GLOBAL_LIMIT_CENTS=5000   # $50/day total
COST_ALERT_WEBHOOK_URL=

# ── Beta ──
BETA_INVITE_CODES=
BETA_MAX_USERS=500

# ── Rate Limiting ──
THROTTLE_TTL=60
THROTTLE_LIMIT=60
THROTTLE_AUTH_LIMIT=5
